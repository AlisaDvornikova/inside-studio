<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INSIDE | Творческое пространство</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Твой кастомный CSS -->
    <link rel="stylesheet" href="/css/style.css?v=161">
</head>
<body class="page-<%= typeof currentPage !== 'undefined' ? currentPage : 'home' %>">

<!-- Навбар -->
<nav class="navbar navbar-expand-lg fixed-top mx-auto" id="mainNavbar">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <img src="/images/logo-icon.png" alt="INSIDE" class="logo-image">
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a class="nav-link" href="/">Главная</a></li>
                <li class="nav-item"><a class="nav-link" href="/trainers">Тренеры</a></li>
                <li class="nav-item"><a class="nav-link" href="/schedule">Расписание</a></li>
                <li class="nav-item"><a class="nav-link" href="/prices">Цены</a></li>
                <li class="nav-item"><a class="nav-link" href="/merch">Мерч</a></li>
            </ul>
            
            <div class="navbar-buttons">
                <% if (user) { %>
                    <a href="/profile" class="btn-profile-custom">
                        <i class="fas fa-user"></i> <%= user.first_name || user.name || user.phone %>
                    </a>
                <% } else { %>
                    <a href="/login" class="btn-login-custom">Вход</a>
                    <a href="/register" class="btn-register-custom">Регистрация</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>

<main>