<script>
    function checkAuthAndBuy(subscriptionId) {
        // Проверяем авторизацию через fetch
        fetch('/check-auth')
            .then(response => response.json())
            .then(data => {
                if (data.authenticated) {
                    // Если авторизован — переходим к оплате
                    window.location.href = `/buy/${subscriptionId}`;
                } else {
                    // Если не авторизован — спрашиваем и перенаправляем на логин
                    if (confirm('Для покупки абонемента необходимо войти или зарегистрироваться. Перейти на страницу входа?')) {
                        window.location.href = '/login';
                    }
                }
            })
            .catch(error => {
                console.error('Ошибка проверки авторизации:', error);
                // Если ошибка, пробуем прямой переход
                window.location.href = `/buy/${subscriptionId}`;
            });
    }
</script>

