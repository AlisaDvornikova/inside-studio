<section class="reviews-page">
    <div class="container">
        <h2>Отзывы наших учеников</h2>
        
        <div class="reviews-list">
            <% reviews.forEach(review => { %>
                <div class="review-card">
                    <div class="review-header">
                        <strong><%= review.name %></strong>
                        <div class="rating">
                            <%= '★'.repeat(review.rating) %><%= '☆'.repeat(5-review.rating) %>
                        </div>
                    </div>
                    <p><%= review.text %></p>
                    <small><%= new Date(review.created_at).toLocaleDateString('ru-RU') %></small>
                </div>
            <% }); %>
            
            <% if (reviews.length === 0) { %>
                <p>Пока нет отзывов. Будьте первыми!</p>
            <% } %>
        </div>
        
        <% if (user) { %>
            <div class="add-review">
                <h3>Оставить отзыв</h3>
                <form action="/reviews/add" method="POST">
                    <div class="form-group">
                        <label>Оценка</label>
                        <select name="rating" required>
                            <option value="5">5 - Отлично</option>
                            <option value="4">4 - Хорошо</option>
                            <option value="3">3 - Средне</option>
                            <option value="2">2 - Плохо</option>
                            <option value="1">1 - Ужасно</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Ваш отзыв</label>
                        <textarea name="text" rows="4" required placeholder="Расскажите о своих впечатлениях..."></textarea>
                    </div>
                    <button type="submit" class="btn">Отправить отзыв</button>
                </form>
            </div>
        <% } else { %>
            <p><a href="/login">Войдите</a>, чтобы оставить отзыв</p>
        <% } %>
    </div>
</section>