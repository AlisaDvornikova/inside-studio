<%- include('../partials/header', { currentPage: 'admin' }) %>

<section class="edit-review-page">
    <div class="container">
        <div class="edit-review-container">
            <h2>Редактирование отзыва</h2>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-message">❌ Ошибка при сохранении отзыва</div>
            <% } %>
            
            <div class="review-info">
                <p><strong>Пользователь:</strong> <%= review.user_name %></p>
                <p><strong>Дата:</strong> <%= new Date(review.created_at).toLocaleDateString('ru-RU') %></p>
            </div>
            
            <form action="/admin/edit-review/<%= review.id %>" method="POST" class="edit-review-form">
                <div class="form-group">
                    <label>Оценка</label>
                    <select name="rating" class="form-control" required>
                        <option value="5" <%= review.rating == 5 ? 'selected' : '' %>>★★★★★ (5 - Отлично)</option>
                        <option value="4" <%= review.rating == 4 ? 'selected' : '' %>>★★★★☆ (4 - Хорошо)</option>
                        <option value="3" <%= review.rating == 3 ? 'selected' : '' %>>★★★☆☆ (3 - Средне)</option>
                        <option value="2" <%= review.rating == 2 ? 'selected' : '' %>>★★☆☆☆ (2 - Плохо)</option>
                        <option value="1" <%= review.rating == 1 ? 'selected' : '' %>>★☆☆☆☆ (1 - Ужасно)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Текст отзыва</label>
                    <textarea name="text" class="form-control" rows="6" required><%= review.text %></textarea>
                </div>
                <div class="form-buttons">
                    <button type="submit" class="btn-start">Сохранить изменения</button>
                    <a href="/profile?tab=manage-reviews" class="btn-outline">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>